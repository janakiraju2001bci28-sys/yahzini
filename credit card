# Enter your code here. Read input from STDIN. Print output to STDOUT
import re

# Read the number of credit card numbers to check
for _ in range(int(input())):
    card = input().strip()
    
    # Condition 1-5: Starts with 4, 5, or 6; exactly 16 digits; 
    # either all digits or groups of 4 separated by '-'
    # Regex Breakdown:
    # ^[456] : Starts with 4, 5, or 6
    # \d{3} : Followed by 3 digits
    # (-?\d{4}){3} : Followed by three groups, each starting with an optional '-' and 4 digits
    # $ : End of string
    structure_match = re.fullmatch(r"^[456]\d{3}(-?\d{4}){3}$", card)
    
    if structure_match:
        # Condition 6: No 4 or more consecutive repeated digits
        # Remove hyphens first for clean comparison
        clean_card = card.replace("-", "")
        # Look for any digit followed by the same digit 3 more times
        if re.search(r"(\d)\1{3,}", clean_card):
            print("Invalid")
        else:
            print("Valid")
    else:
        print("Invalid")
