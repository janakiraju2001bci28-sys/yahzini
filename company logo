#!/bin/python3

import math
import os
import random
import re
import sys



from collections import Counter

if __name__ == '__main__':
    # Sort the string alphabetically first to handle ties correctly
    s = sorted(input())
    
    # Count character frequencies
    counts = Counter(s)
    
    # Extract the 3 most common characters
    # most_common() maintains the relative order of elements with the same count
    for char, count in counts.most_common(3):
        print(char, count)

