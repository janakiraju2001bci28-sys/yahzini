def fibonacci(n):
    # 2. Return a list of the first n fibonacci numbers
    if n <= 0:
        return []
    elif n == 1:
        return [0]
    
    # Starting sequence with first two numbers
    fib_list = [0, 1]
    
    # Generate the rest of the sequence up to n
    while len(fib_list) < n:
        # Sum of the last two elements
        next_val = fib_list[-1] + fib_list[-2]
        fib_list.append(next_val)
        
    return fib_list


