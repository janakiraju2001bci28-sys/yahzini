def count_substring(string, sub_string):
    count = 0
    # Iterate through the string, checking each potential starting position
    for i in range(len(string) - len(sub_string) + 1):
        # Use slicing to check if the substring matches at current index
        if string[i : i + len(sub_string)] == sub_string:
            count += 1
    return count
